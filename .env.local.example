NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Bandeja de mails — IMAP (casilla compartida con app password de Gmail)
INBOX_IMAP_HOST=imap.gmail.com
INBOX_IMAP_PORT=993
INBOX_IMAP_USER=argeninta-demo-bandeja@gmail.com
INBOX_IMAP_PASSWORD=tu-app-password
INBOX_IMAP_TLS=true

# Secreto para autenticar invocaciones manuales del cron de sync IMAP
# (en prod, Vercel auto-inyecta x-vercel-cron-signature; este secret
# es para curl/scripts de dev contra el endpoint deployado)
CRON_SECRET=cambiame-32chars-aleatorios

# OCR via Claude API — prueba contra doctr local.
# Sin esto, el botón "Comparar OCR vs Claude" no funciona.
# Default model: claude-haiku-4-5 (el más barato y rápido).
# Override opcional: ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
